<Window x:Class="WebVulnScanner.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:WebVulnScanner.Desktop.Converters"
        mc:Ignorable="d"
        Title="Web Vulnerability Scanner - Professional Edition"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <conv:SeverityColorConverter x:Key="SeverityConverter"/>

        <SolidColorBrush x:Key="BrushBackground" Color="#0F172A"/>
        <SolidColorBrush x:Key="BrushSurface" Color="#111827"/>
        <SolidColorBrush x:Key="BrushSurfaceAlt" Color="#1F2937"/>
        <SolidColorBrush x:Key="BrushBorder" Color="#334155"/>
        <SolidColorBrush x:Key="BrushTextPrimary" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="BrushTextSecondary" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="BrushChromeBackground" Color="#0B1220"/>
        <SolidColorBrush x:Key="BrushTabBackground" Color="#1F2937"/>
        <SolidColorBrush x:Key="BrushTabSelectedBackground" Color="#0F172A"/>
        <SolidColorBrush x:Key="BrushTabHoverBackground" Color="#334155"/>
        <SolidColorBrush x:Key="BrushDataGridRow" Color="#0F1A2E"/>
        <SolidColorBrush x:Key="BrushDataGridRowAlt" Color="#111F36"/>
        <SolidColorBrush x:Key="BrushDataGridRowHover" Color="#1E3A5F"/>
        <SolidColorBrush x:Key="BrushDataGridRowSelected" Color="#0EA5E9"/>
        <SolidColorBrush x:Key="BrushDataGridGridlineH" Color="#243244"/>
        <SolidColorBrush x:Key="BrushDataGridGridlineV" Color="#1B2533"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style TargetType="TabItem">
    <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
    <Setter Property="Background" Value="{StaticResource BrushTabBackground}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="14,8"/>
    <Setter Property="Margin" Value="4,0,4,0"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="TabItem">
                <Border x:Name="TabBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6,6,0,0"
                        Margin="{TemplateBinding Margin}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter x:Name="TabContent"
                                      ContentSource="Header"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      TextBlock.Foreground="{TemplateBinding Foreground}"
                                      TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource BrushTabSelectedBackground}"/>
                        <Setter TargetName="TabBorder" Property="BorderBrush" Value="#38BDF8"/>
                        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource BrushTabHoverBackground}"/>
                        <Setter TargetName="TabBorder" Property="BorderBrush" Value="#38BDF8"/>
                        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource BrushSurface}"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BrushDataGridGridlineH}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BrushDataGridGridlineV}"/>
            <Setter Property="RowBackground" Value="{StaticResource BrushDataGridRow}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BrushDataGridRowAlt}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{StaticResource BrushSurfaceAlt}"/>
                        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Height" Value="38"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#0EA5E9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0284C7"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#000000"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ToggleButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0284C7"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#000000"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrushDataGridRowHover}"/>
                    <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrushDataGridRowSelected}"/>
                    <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BrushSurfaceAlt}"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="BorderBrush" Value="#FFFFFF22"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BrushBackground}">
        <Border Margin="14" Padding="10" Background="{StaticResource BrushChromeBackground}" CornerRadius="14" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
            <TabControl Margin="8">
            <TabItem Header="Dashboard">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <UniformGrid Columns="4" Margin="6,6,6,12">
                        <Border Style="{StaticResource StatCardStyle}" Background="#2563EB">
                            <StackPanel>
                                <TextBlock Text="TOTAL SCANS" Foreground="White" Opacity="0.8"/>
                                <TextBlock Text="{Binding TotalScans}" FontSize="36" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCardStyle}" Background="#DC2626">
                            <StackPanel>
                                <TextBlock Text="CRITICAL RISKS" Foreground="White" Opacity="0.8"/>
                                <TextBlock Text="{Binding CriticalCount}" FontSize="36" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCardStyle}" Background="#D97706">
                            <StackPanel>
                                <TextBlock Text="PROXY REQUESTS" Foreground="White" Opacity="0.8"/>
                                <TextBlock Text="{Binding ProxyRequestCount}" FontSize="36" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCardStyle}" Background="#059669">
                            <StackPanel>
                                <TextBlock Text="ACTIVE SCANS" Foreground="White" Opacity="0.8"/>
                                <TextBlock Text="{Binding ActiveScans}" FontSize="36" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding RecentScans}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Margin="6" SelectionChanged="ScansGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding ScanDate, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="150"/>
                            <DataGridTextColumn Header="Target" Binding="{Binding TargetUrl}" Width="*"/>
                            <DataGridTextColumn Header="Pages" Binding="{Binding PagesScanned}" Width="80"/>
                            <DataGridTextColumn Header="Issues" Binding="{Binding VulnerabilityCount}" Width="80"/>
                            <DataGridTemplateColumn Header="Risk Score" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ProgressBar Value="{Binding RiskScore}" Maximum="100"
                                                     Background="{Binding RiskScore, Converter={StaticResource SeverityConverter}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Scanner">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Target URL:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtTarget" Width="500" FontSize="14" Padding="5"
                                 Text="" ToolTip="Enter the target URL to scan"/>
                        <CheckBox x:Name="chkDeepScan" Content="Deep Scan (Crawl)" Margin="15,0" VerticalAlignment="Center"/>
                        <Button x:Name="btnScan" Content="Start Scan" Padding="20,5"
                                Background="#16A34A" Foreground="White" FontWeight="Bold"
                                Click="BtnScan_Click"/>
                        <Button Content="Generate Report" Margin="10,0,0,0" Padding="15,5" Background="#0284C7"
                                Click="BtnReport_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="10" Padding="8">
                        <ProgressBar x:Name="progressScan" Height="20" IsIndeterminate="False"/>
                    </Border>

                    <DataGrid x:Name="gridVulns" Grid.Row="2" Margin="0,10,0,0" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Background" Value="{Binding Severity, Converter={StaticResource SeverityConverter}}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Padding" Value="5"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="150"/>
                            <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="300"/>
                            <DataGridTextColumn Header="Remediation" Binding="{Binding Remediation}" Width="250"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Proxy Interceptor">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource BrushSurface}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            CornerRadius="12" Padding="10" Margin="0,0,0,8">
                        <WrapPanel VerticalAlignment="Center" ItemHeight="36">
                            <ToggleButton x:Name="btnProxyToggle" Content="● Proxy OFF"
                                          Click="BtnProxyToggle_Click" Background="#DC2626" Margin="0,0,8,0"/>
                            <ToggleButton x:Name="btnIntercept" Content="⏸ Intercept ON" IsChecked="True"
                                          Checked="BtnIntercept_Checked" Unchecked="BtnIntercept_Unchecked"
                                          Background="#0284C7" Margin="0,0,8,0"/>
                            <Button Content="▶ Forward" Click="BtnForward_Click" Background="#16A34A"/>
                            <Button Content="⏩ Forward All" Click="BtnForwardAll_Click" Background="#22C55E"/>
                            <Button Content="✕ Drop" Click="BtnDrop_Click" Background="#EA580C"/>
                            <Button Content="Clear" Click="BtnClearProxy_Click" Background="#475569"/>
                            <Button Content="Copy Raw" Click="BtnCopyRequest_Click" Background="#0EA5E9"/>
                            <Separator Width="1" Background="#334155" Margin="8,4"/>
                            <TextBlock Text="Port:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="txtProxyPort" Text="8080" Width="70" Margin="0,0,10,0"/>
                            <TextBlock x:Name="txtProxyStatus" Text="Listening..." VerticalAlignment="Center" Foreground="#38BDF8"/>
                        </WrapPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="50*"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid x:Name="gridProxy" Grid.Column="0"
                                  SelectionChanged="GridProxy_SelectionChanged"
                                  AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40"/>
                                <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="70"/>
                                <DataGridTextColumn Header="Code" Binding="{Binding StatusCode}" Width="55"/>
                                <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="160"/>
                                <DataGridTextColumn Header="Path" Binding="{Binding Url}" Width="*"/>
                                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#334155"/>

                        <TabControl Grid.Column="2" Margin="5,0,0,0">
                            <TabItem Header="Request">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Edit &amp; Forward Request" FontWeight="Bold"
                                               Margin="8,8,0,4" Foreground="#38BDF8"/>
                                    <TextBox x:Name="txtRequestEditor" Grid.Row="1"
                                             FontFamily="Consolas" FontSize="12"
                                             TextWrapping="Wrap" AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             Background="#0B1220" Foreground="#E2E8F0"
                                             BorderThickness="0" Padding="8"/>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Response">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="8,8,0,4">
                                        <TextBlock Text="Response" FontWeight="Bold" Foreground="#38BDF8"/>
                                        <TextBlock x:Name="txtStatusCode" Margin="12,0,0,0" Foreground="#4ADE80"/>
                                    </StackPanel>
                                    <TextBox x:Name="txtResponseViewer" Grid.Row="1"
                                             FontFamily="Consolas" FontSize="12"
                                             TextWrapping="Wrap" AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             IsReadOnly="True"
                                             Background="#0B1220" Foreground="#94A3B8"
                                             BorderThickness="0" Padding="8"/>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Repeater">
                <Grid Margin="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBox x:Name="txtRepeaterUrl" Width="300" Text="" ToolTip="Enter request URL (for example: https://api.site.com/endpoint)"/>
                            <Button Content="Send" Click="BtnRepeaterSend_Click" Background="#16A34A"/>
                            <Button Content="Clear" Background="#475569" Click="BtnRepeaterClear_Click"/>
                        </StackPanel>
                        <TextBox x:Name="txtRepeaterRequest" Grid.Row="1"
                                 FontFamily="Consolas" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                    </Grid>

                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#334155"/>

                    <Grid Grid.Column="2" Margin="5,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock x:Name="txtRepeaterStatus" Text="Status: —" VerticalAlignment="Center" Margin="8,0"/>
                            <TextBlock x:Name="txtRepeaterTime" Text="Time: —ms" Margin="16,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtRepeaterLength" Text="Length: —" Margin="16,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBox x:Name="txtRepeaterResponse" Grid.Row="1"
                                 FontFamily="Consolas" IsReadOnly="True"
                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Headers">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="URL:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="txtHeaderUrl" Width="480" Text="" ToolTip="Enter a URL to analyze response headers"/>
                        <Button Content="Analyze Headers" Click="BtnAnalyzeHeaders_Click" Background="#0284C7"/>
                    </StackPanel>

                    <DataGrid x:Name="gridHeaderFindings" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Header" Binding="{Binding Header}" Width="220"/>
                            <DataGridTextColumn Header="Present" Binding="{Binding Present}" Width="80"/>
                            <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="240"/>
                            <DataGridTextColumn Header="Risk" Binding="{Binding Risk}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Encoder">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="txtEncodeInput" Grid.Row="0" AcceptsReturn="True"
                             FontFamily="Consolas" VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap" Text="" ToolTip="Enter text to encode or decode"/>

                    <WrapPanel Grid.Row="1" Margin="0,8">
                        <Button Content="Base64 Encode" Click="Encode_Base64"/>
                        <Button Content="Base64 Decode" Click="Decode_Base64"/>
                        <Button Content="URL Encode" Click="Encode_Url"/>
                        <Button Content="URL Decode" Click="Decode_Url"/>
                        <Button Content="HTML Encode" Click="Encode_Html"/>
                        <Button Content="HTML Decode" Click="Decode_Html"/>
                        <Button Content="MD5 Hash" Click="Hash_MD5"/>
                        <Button Content="SHA256 Hash" Click="Hash_SHA256"/>
                        <Button Content="JWT Decode" Click="Decode_JWT" Background="#7C3AED"/>
                        <Button Content="Hex Encode" Click="Encode_Hex"/>
                        <Button Content="Hex Decode" Click="Decode_Hex"/>
                    </WrapPanel>

                    <TextBox x:Name="txtEncodeOutput" Grid.Row="2" AcceptsReturn="True"
                             FontFamily="Consolas" IsReadOnly="True"
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </TabItem>

            <TabItem Header="Net Scanner">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource BrushSurface}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            CornerRadius="10" Padding="10" Margin="0,0,0,8">
                        <WrapPanel ItemHeight="32">
                            <TextBlock Text="Target:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="txtNmapTarget" Width="260" Text=""
                                     ToolTip="IP, hostname, or CIDR range (for example: 192.168.1.0/24)"/>

                            <TextBlock Text="Ports:" VerticalAlignment="Center" Margin="12,0,6,0"/>
                            <TextBox x:Name="txtNmapPorts" Width="140" Text="1-1024"
                                     ToolTip="e.g. 22,80,443 or 1-65535 or top100"/>

                            <TextBlock Text="Scan type:" VerticalAlignment="Center" Margin="12,0,6,0"/>
                            <ComboBox x:Name="cmbScanType" Width="130" SelectedIndex="0">
                                <ComboBoxItem Content="TCP Connect"/>
                                <ComboBoxItem Content="SYN Stealth"/>
                                <ComboBoxItem Content="UDP"/>
                                <ComboBoxItem Content="Ping Only"/>
                                <ComboBoxItem Content="Full (All)"/>
                            </ComboBox>

                            <CheckBox x:Name="chkServiceDetect" Content="Service detect"
                                      Margin="12,0" VerticalAlignment="Center" IsChecked="True"/>
                            <CheckBox x:Name="chkOsDetect" Content="OS detect"
                                      Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <CheckBox x:Name="chkVulnCheck" Content="Vuln check"
                                      Margin="0,0,12,0" VerticalAlignment="Center"/>

                            <Button x:Name="btnNmapScan" Content="Start Scan"
                                    Background="#16A34A" Click="BtnNmapScan_Click"/>
                            <Button x:Name="btnNmapStop" Content="Stop" IsEnabled="False"
                                    Background="#DC2626" Click="BtnNmapStop_Click"/>
                            <Button Content="Export" Background="#0284C7"
                                    Click="BtnNmapExport_Click"/>
                        </WrapPanel>
                    </Border>

                    <Border Grid.Row="1" Background="{StaticResource BrushSurface}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            CornerRadius="8" Padding="8" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ProgressBar x:Name="progressNmap" Height="16" IsIndeterminate="False"/>
                            <TextBlock x:Name="txtNmapStatus" Grid.Column="1"
                                       Margin="12,0,0,0" VerticalAlignment="Center"
                                       Text="Ready" Foreground="#38BDF8"/>
                        </Grid>
                    </Border>

                    <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,8">
                        <Border Background="#1E3A5F" CornerRadius="8" Padding="10" Margin="0,0,4,0">
                            <StackPanel>
                                <TextBlock Text="Hosts up" FontSize="11" Foreground="#94A3B8"/>
                                <TextBlock x:Name="txtHostsUp" Text="0" FontSize="22"
                                           FontWeight="Bold" Foreground="#38BDF8"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1A2E1A" CornerRadius="8" Padding="10" Margin="2,0,2,0">
                            <StackPanel>
                                <TextBlock Text="Open ports" FontSize="11" Foreground="#94A3B8"/>
                                <TextBlock x:Name="txtOpenPorts" Text="0" FontSize="22"
                                           FontWeight="Bold" Foreground="#4ADE80"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#2E1A1A" CornerRadius="8" Padding="10" Margin="2,0,2,0">
                            <StackPanel>
                                <TextBlock Text="Vulnerabilities" FontSize="11" Foreground="#94A3B8"/>
                                <TextBlock x:Name="txtVulnCount" Text="0" FontSize="22"
                                           FontWeight="Bold" Foreground="#F87171"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1E1A2E" CornerRadius="8" Padding="10" Margin="4,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Scan time" FontSize="11" Foreground="#94A3B8"/>
                                <TextBlock x:Name="txtScanTime" Text="0s" FontSize="22"
                                           FontWeight="Bold" Foreground="#A78BFA"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="{StaticResource BrushSurface}"
                                BorderBrush="{StaticResource BrushBorder}"
                                BorderThickness="1" CornerRadius="10" Padding="6">
                            <TreeView x:Name="treeHosts"
                                      SelectedItemChanged="TreeHosts_SelectedItemChanged"
                                      Background="Transparent"/>
                        </Border>

                        <GridSplitter Grid.Column="1" Width="5"
                                      HorizontalAlignment="Stretch" Background="#334155"/>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="220"/>
                            </Grid.RowDefinitions>

                            <DataGrid x:Name="gridPorts"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionChanged="GridPorts_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="70"/>
                                    <DataGridTextColumn Header="Protocol" Binding="{Binding Protocol}" Width="80"/>
                                    <DataGridTextColumn Header="State" Binding="{Binding State}" Width="80"/>
                                    <DataGridTextColumn Header="Service" Binding="{Binding Service}" Width="120"/>
                                    <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="160"/>
                                    <DataGridTextColumn Header="Risk" Binding="{Binding Risk}" Width="80"/>
                                    <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Grid.Row="1" Margin="0,8,0,0"
                                    Background="{StaticResource BrushSurface}"
                                    BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="1" CornerRadius="10" Padding="10">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="Vulnerability Details" FontWeight="Bold" FontSize="14" Foreground="#F8FAFC"/>
                                        <TextBlock x:Name="txtVulnName" Margin="0,6,0,0" Text="Select a port to view details" Foreground="#E2E8F0"/>
                                        <TextBlock x:Name="txtVulnRisk" Margin="0,4,0,0" Foreground="#E2E8F0"/>
                                        <TextBlock x:Name="txtVulnDescription" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#CBD5E1"/>
                                        <TextBlock x:Name="txtVulnCVEs" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#CBD5E1"/>
                                        <TextBlock x:Name="txtVulnImpact" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#CBD5E1"/>
                                        <TextBlock x:Name="txtVulnFix" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#CBD5E1"/>
                                        <TextBlock x:Name="txtVulnTools" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#CBD5E1"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Nmap Scanner">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource BrushSurface}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            CornerRadius="10" Padding="10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <WrapPanel ItemHeight="32">
                                <TextBlock Text="Target:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="txtAdvNmapTarget" Width="240" Text=""
                                         ToolTip="Enter IP, host, or CIDR"/>

                                <TextBlock Text="Profile:" VerticalAlignment="Center" Margin="12,0,6,0"/>
                                <ComboBox x:Name="cmbAdvNmapProfile" Width="250" SelectedIndex="0"
                                          SelectionChanged="CmbAdvNmapProfile_SelectionChanged">
                                    <ComboBoxItem Content="SMB: MS17-010 + protocols"/>
                                    <ComboBoxItem Content="SMB: all vuln scripts"/>
                                    <ComboBoxItem Content="SMB: protocols + security mode"/>
                                    <ComboBoxItem Content="Top 100 ports"/>
                                    <ComboBoxItem Content="Top 1000 ports"/>
                                    <ComboBoxItem Content="Custom command"/>
                                </ComboBox>

                                <Button x:Name="btnAdvNmapStart" Content="Run Nmap"
                                        Background="#16A34A" Click="BtnAdvNmapStart_Click"/>
                                <Button x:Name="btnAdvNmapStop" Content="Stop" IsEnabled="False"
                                        Background="#DC2626" Click="BtnAdvNmapStop_Click"/>
                                <Button x:Name="btnAdvNmapCopy" Content="Copy Cmd"
                                        Background="#0284C7" Click="BtnAdvNmapCopy_Click"/>
                            </WrapPanel>

                            <TextBox x:Name="txtAdvNmapCommand" Grid.Row="1" Margin="0,8,0,0"
                                     FontFamily="Consolas" IsReadOnly="True"
                                     Background="#0B1220" Foreground="#38BDF8"
                                     BorderBrush="#334155" BorderThickness="1"
                                     Text="nmap -p 445 --script smb-vuln-ms17-010,smb-protocols,smb2-security-mode -v target-host"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="{StaticResource BrushSurface}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            CornerRadius="8" Padding="8" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="borderAdvNmapStatus" CornerRadius="6" Padding="8,2" Background="#0F4418" BorderBrush="#16A34A" BorderThickness="1">
                                <TextBlock x:Name="txtAdvNmapInstallStatus" Text="Nmap: checking..." Foreground="#4ADE80"/>
                            </Border>

                            <ProgressBar x:Name="progressAdvNmap" Grid.Column="1" Height="14" Margin="12,0,12,0"/>
                            <TextBlock x:Name="txtAdvNmapStatus" Grid.Column="2" Text="Ready" VerticalAlignment="Center" Foreground="#38BDF8"/>
                        </Grid>
                    </Border>

                    <Border x:Name="riskResultBorder" Grid.Row="2" Visibility="Collapsed"
                            Background="#051A0A" BorderBrush="#16A34A" BorderThickness="1"
                            CornerRadius="10" Padding="10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="verdictBadge" Grid.Column="0" CornerRadius="8"
                                    Background="#0B1220" BorderBrush="#16A34A" BorderThickness="2" Padding="10">
                                <StackPanel>
                                    <TextBlock x:Name="txtVerdictIcon" Text="SAFE" FontSize="12" FontWeight="Bold" Foreground="#94A3B8"/>
                                    <TextBlock x:Name="txtVerdictMain" Text="SAFE" Margin="0,4,0,0" FontSize="22" FontWeight="Bold" Foreground="#F8FAFC"/>
                                    <TextBlock x:Name="txtVerdictTarget" Text="-" Margin="0,6,0,0" FontWeight="SemiBold" Foreground="#38BDF8"/>
                                    <TextBlock x:Name="txtVerdictDetail" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#CBD5E1"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#0B1220" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Findings" FontWeight="Bold" Foreground="#F8FAFC"/>
                                        <ListBox x:Name="listRiskFindings" Margin="0,6,0,0" BorderThickness="0" Background="Transparent" Foreground="#E2E8F0">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,0,0,6">
                                                        <TextBlock Text="{Binding LevelText, StringFormat=• [{0}]}" FontWeight="SemiBold" Foreground="#FCA5A5"/>
                                                        <TextBlock Text="{Binding Title}" TextWrapping="Wrap" Foreground="#E2E8F0"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="8,0">
                                        <TextBlock Text="Safe Points" FontWeight="Bold" Foreground="#F8FAFC"/>
                                        <ListBox x:Name="listSafePoints" Margin="0,6,0,0" BorderThickness="0" Background="Transparent" Foreground="#86EFAC">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,6" Text="{Binding StringFormat=• {0}}"/>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                        <TextBlock Text="Next Steps" FontWeight="Bold" Foreground="#F8FAFC"/>
                                        <ListBox x:Name="listNextSteps" Margin="0,6,0,0" BorderThickness="0" Background="Transparent" Foreground="#38BDF8">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,6" Text="{Binding StringFormat=• {0}}"/>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="{StaticResource BrushSurface}"
                                BorderBrush="{StaticResource BrushBorder}"
                                BorderThickness="1" CornerRadius="10" Padding="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Open Ports" FontWeight="Bold" Foreground="#F8FAFC" Margin="0,0,0,6"/>
                                <DataGrid x:Name="gridAdvNmapPorts" Grid.Row="1"
                                          AutoGenerateColumns="False" IsReadOnly="True"
                                          SelectionChanged="GridAdvNmapPorts_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="60"/>
                                        <DataGridTextColumn Header="Service" Binding="{Binding Service}" Width="90"/>
                                        <DataGridTextColumn Header="State" Binding="{Binding State}" Width="65"/>
                                        <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="130"/>
                                        <DataGridTextColumn Header="Risk" Binding="{Binding RiskLevel}" Width="70"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="#334155"/>

                        <Border Grid.Column="2" Background="{StaticResource BrushSurface}"
                                BorderBrush="{StaticResource BrushBorder}"
                                BorderThickness="1" CornerRadius="10" Padding="10">
                            <ScrollViewer x:Name="scrollAdvNmapDetail" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock x:Name="txtAdvNmapDetailHeader" Text="Select a port" FontWeight="Bold" FontSize="14" Foreground="#F8FAFC"/>
                                    <TextBlock x:Name="txtAdvNmapDetailService" Margin="0,6,0,0" Foreground="#E2E8F0"/>
                                    <TextBlock x:Name="txtAdvNmapDetailRisk" Margin="0,6,0,0" Foreground="#FBBF24" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="txtAdvNmapDetailDescription" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#CBD5E1"/>
                                    <TextBlock x:Name="txtAdvNmapMs17010" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#E2E8F0"/>
                                    <TextBlock x:Name="txtAdvNmapNextCommands" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#38BDF8"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <GridSplitter Grid.Column="3" Width="6" HorizontalAlignment="Stretch" Background="#334155"/>

                        <Border Grid.Column="4" Background="{StaticResource BrushSurface}"
                                BorderBrush="{StaticResource BrushBorder}"
                                BorderThickness="1" CornerRadius="10" Padding="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Raw Nmap Output" FontWeight="Bold" Foreground="#F8FAFC" Margin="0,0,0,6"/>
                                <TextBox x:Name="txtAdvNmapRawOutput" Grid.Row="1"
                                         FontFamily="Consolas" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         TextWrapping="NoWrap"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="OpenVAS">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource BrushSurface}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1" CornerRadius="10"
                            Padding="10" Margin="0,0,0,8">
                        <WrapPanel ItemHeight="32">
                            <TextBlock Text="Host:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="txtOvasHost" Width="140" Text="" ToolTip="OpenVAS host (for example: localhost or server IP)"/>

                            <TextBlock Text="Port:" VerticalAlignment="Center" Margin="10,0,6,0"/>
                            <TextBox x:Name="txtOvasPort" Width="60" Text="9390"/>

                            <TextBlock Text="User:" VerticalAlignment="Center" Margin="10,0,6,0"/>
                            <TextBox x:Name="txtOvasUser" Width="80" Text="admin"/>

                            <TextBlock Text="Pass:" VerticalAlignment="Center" Margin="10,0,6,0"/>
                            <PasswordBox x:Name="pwdOvas" Width="90"/>

                            <Button Content="Test Connection"
                                    Background="#475569" Margin="10,0,0,0"
                                    Click="BtnOvasTestConn_Click"/>

                            <Border x:Name="ovasConnBadge"
                                    CornerRadius="4" Padding="8,3" Margin="8,0,0,0"
                                    VerticalAlignment="Center" Background="#1E293B">
                                <TextBlock x:Name="ovasConnStatus"
                                           Text="Not connected"
                                           FontSize="11" FontWeight="Bold" Foreground="#CBD5E1"/>
                            </Border>
                        </WrapPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{StaticResource BrushSurface}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1" CornerRadius="10"
                            Padding="10" Margin="0,0,0,8">
                        <WrapPanel ItemHeight="32">
                            <TextBlock Text="Target:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="txtOvasTarget" Width="220"
                                     Text=""
                                     ToolTip="IP, hostname, or CIDR range (e.g. 192.168.1.0/24)"/>

                            <TextBlock Text="Profile:" VerticalAlignment="Center" Margin="10,0,6,0"/>
                            <ComboBox x:Name="cmbOvasProfile" Width="220" SelectedIndex="0">
                                <ComboBoxItem Content="Full and fast (recommended)"/>
                                <ComboBoxItem Content="Full and fast ultimate"/>
                                <ComboBoxItem Content="System Discovery"/>
                                <ComboBoxItem Content="Host Discovery (ping only)"/>
                            </ComboBox>

                            <TextBlock Text="Task name:" VerticalAlignment="Center" Margin="10,0,6,0"/>
                            <TextBox x:Name="txtOvasTaskName" Width="160"
                                     Text="VulnFinder Scan"/>

                            <Button x:Name="btnOvasScan" Content="Start OpenVAS Scan"
                                    Background="#16A34A" Margin="10,0,0,0"
                                    Click="BtnOvasScan_Click"/>
                            <Button x:Name="btnOvasStop" Content="Stop"
                                    Background="#DC2626" IsEnabled="False"
                                    Click="BtnOvasStop_Click"/>
                            <Button Content="Export XML" Background="#0284C7"
                                    Click="BtnOvasExport_Click"/>
                        </WrapPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Background="{StaticResource BrushSurface}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="8" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="5"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock x:Name="txtOvasStatus"
                                           Text="Ready — configure connection and click Start"
                                           FontSize="12" Foreground="#38BDF8"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtOvasPercent"
                                           Text="" FontSize="12" FontWeight="Bold"
                                           Foreground="#38BDF8" Margin="12,0,0,0"/>
                            </StackPanel>

                            <ProgressBar x:Name="progressOvas"
                                         Grid.Row="2" Height="14"
                                         IsIndeterminate="False" Value="0"/>
                        </Grid>
                    </Border>

                    <UniformGrid Grid.Row="3" Columns="5" Margin="0,0,0,8">
                        <Border Background="#1A0505" CornerRadius="8"
                                BorderBrush="#7F1D1D" BorderThickness="1"
                                Padding="10" Margin="0,0,3,0">
                            <StackPanel>
                                <TextBlock Text="Critical" FontSize="10" Foreground="#9CA3AF"/>
                                <TextBlock x:Name="ovasCritCount" Text="0"
                                           FontSize="26" FontWeight="Bold" Foreground="#DC2626"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1A0E05" CornerRadius="8"
                                BorderBrush="#7C2D12" BorderThickness="1"
                                Padding="10" Margin="2,0,2,0">
                            <StackPanel>
                                <TextBlock Text="High" FontSize="10" Foreground="#9CA3AF"/>
                                <TextBlock x:Name="ovasHighCount" Text="0"
                                           FontSize="26" FontWeight="Bold" Foreground="#EA580C"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1A1305" CornerRadius="8"
                                BorderBrush="#713F12" BorderThickness="1"
                                Padding="10" Margin="2,0,2,0">
                            <StackPanel>
                                <TextBlock Text="Medium" FontSize="10" Foreground="#9CA3AF"/>
                                <TextBlock x:Name="ovasMedCount" Text="0"
                                           FontSize="26" FontWeight="Bold" Foreground="#D97706"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#05101A" CornerRadius="8"
                                BorderBrush="#1E3A5F" BorderThickness="1"
                                Padding="10" Margin="2,0,2,0">
                            <StackPanel>
                                <TextBlock Text="Low" FontSize="10" Foreground="#9CA3AF"/>
                                <TextBlock x:Name="ovasLowCount" Text="0"
                                           FontSize="26" FontWeight="Bold" Foreground="#2563EB"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#0A1A0A" CornerRadius="8"
                                BorderBrush="#14532D" BorderThickness="1"
                                Padding="10" Margin="3,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Total CVEs" FontSize="10" Foreground="#9CA3AF"/>
                                <TextBlock x:Name="ovasTotalCount" Text="0"
                                           FontSize="26" FontWeight="Bold" Foreground="#4ADE80"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="55*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="45*"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid x:Name="gridOvasResults"
                                  Grid.Column="0"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionChanged="GridOvasResults_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Severity" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="4,2" Margin="2"
                                                    Background="{Binding SeverityColor}">
                                                <TextBlock Text="{Binding SeverityUpper}"
                                                           Foreground="White" FontSize="10"
                                                           FontWeight="Bold" TextAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="CVSS"
                                                    Binding="{Binding CvssDisplay}"
                                                    Width="55"/>
                                <DataGridTextColumn Header="CVE"
                                                    Binding="{Binding CveId}"
                                                    Width="130"/>
                                <DataGridTextColumn Header="Host"
                                                    Binding="{Binding Host}"
                                                    Width="120"/>
                                <DataGridTextColumn Header="Port"
                                                    Binding="{Binding Port}"
                                                    Width="70"/>
                                <DataGridTextColumn Header="Vulnerability"
                                                    Binding="{Binding Name}"
                                                    Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <GridSplitter Grid.Column="1" Width="5"
                                      HorizontalAlignment="Stretch"
                                      Background="#334155"/>

                        <Border Grid.Column="2"
                                Background="#080F1C"
                                BorderBrush="#1E293B"
                                BorderThickness="1" CornerRadius="12">
                            <Grid>
                                <Grid x:Name="ovasEmptyPanel">
                                    <StackPanel VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                Opacity="0.3">
                                        <TextBlock Text="Select a vulnerability to view details"
                                                   FontSize="13" Foreground="#334155"
                                                   TextAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <ScrollViewer x:Name="ovasDetailPanel"
                                              Visibility="Collapsed"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="16,14,16,16">
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock x:Name="ovasDetailName"
                                                       FontSize="16" FontWeight="Bold"
                                                       Foreground="#F8FAFC" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="ovasDetailHost"
                                                       FontSize="12" Foreground="#94A3B8"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                x:Name="ovasRiskBadge"
                                                CornerRadius="6" Padding="12,6"
                                                VerticalAlignment="Top" BorderThickness="1">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock x:Name="ovasRiskLabel"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="White" TextAlignment="Center"/>
                                                <TextBlock x:Name="ovasCvssLabel"
                                                           FontSize="18" FontWeight="Bold"
                                                           Foreground="White" TextAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Rectangle Height="1" Fill="#1E293B" Margin="0,0,0,10"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Background="#0F1A0F" CornerRadius="4"
                                                BorderBrush="#14532D" BorderThickness="1"
                                                Padding="8,4" Margin="0,0,8,0">
                                            <TextBlock x:Name="ovasCveId"
                                                       FontFamily="Consolas" FontSize="12"
                                                       Foreground="#4ADE80"/>
                                        </Border>
                                        <Border Background="#0F0A1A" CornerRadius="4"
                                                BorderBrush="#312E81" BorderThickness="1"
                                                Padding="8,4">
                                            <TextBlock x:Name="ovasFamilyName"
                                                       FontSize="11" Foreground="#A78BFA"/>
                                        </Border>
                                    </StackPanel>

                                    <Border Background="#0F172A" CornerRadius="8"
                                            BorderBrush="#1E293B" BorderThickness="1"
                                            Padding="12" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="DESCRIPTION" FontSize="10"
                                                       FontWeight="Bold" Foreground="#38BDF8"
                                                       Margin="0,0,0,6"/>
                                            <TextBlock x:Name="ovasDescription"
                                                       FontSize="12" Foreground="#CBD5E1"
                                                       TextWrapping="Wrap" LineHeight="20"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#0A0F1A" CornerRadius="8"
                                            BorderBrush="#1E3A5F" BorderThickness="1"
                                            Padding="12" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="HOW TO FIX" FontSize="10"
