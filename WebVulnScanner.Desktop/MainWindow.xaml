                          <TabItem Header="credits">
    <Grid Margin="8" ClipToBounds="True">
        <Grid.Resources>

            <!-- Scanline sweep -->
            <Storyboard x:Key="ScanlineStoryboard" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="scanlineTransform"
                                 Storyboard.TargetProperty="Y"
                                 From="-6" To="900"
                                 Duration="0:0:2.8"/>
            </Storyboard>
            <Storyboard x:Key="Scanline2Storyboard" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="scanline2Transform"
                                 Storyboard.TargetProperty="Y"
                                 From="-6" To="900"
                                 Duration="0:0:4.1"
                                 BeginTime="0:0:1.5"/>
            </Storyboard>

            <!-- Cursor blink -->
            <Storyboard x:Key="CursorBlinkStoryboard" RepeatBehavior="Forever" AutoReverse="True">
                <DoubleAnimation Storyboard.TargetName="cursorBlink"
                                 Storyboard.TargetProperty="Opacity"
                                 From="1" To="0"
                                 Duration="0:0:0.5"/>
            </Storyboard>

            <!-- Border pulse -->
            <Storyboard x:Key="BorderPulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
                <ColorAnimation Storyboard.TargetName="creditBorderBrush"
                                Storyboard.TargetProperty="Color"
                                From="#0D3320" To="#22C55E"
                                Duration="0:0:1.6"/>
            </Storyboard>

            <!-- Glow pulse on title -->
            <Storyboard x:Key="GlowPulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
                <DoubleAnimation Storyboard.TargetName="titleGlow"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.3" To="1.0"
                                 Duration="0:0:1.2"/>
            </Storyboard>

            <!-- Corner spin -->
            <Storyboard x:Key="CornerSpinStoryboard" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="cornerRotate"
                                 Storyboard.TargetProperty="Angle"
                                 From="0" To="360"
                                 Duration="0:0:6"/>
            </Storyboard>

            <!-- Flicker overlay -->
            <Storyboard x:Key="FlickerStoryboard" RepeatBehavior="Forever">
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="flickerOverlay"
                                               Storyboard.TargetProperty="Opacity">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="0.00"/>
                    <DiscreteDoubleKeyFrame KeyTime="0:0:1.80" Value="0.00"/>
                    <DiscreteDoubleKeyFrame KeyTime="0:0:1.82" Value="0.06"/>
                    <DiscreteDoubleKeyFrame KeyTime="0:0:1.85" Value="0.00"/>
                    <DiscreteDoubleKeyFrame KeyTime="0:0:3.10" Value="0.00"/>
                    <DiscreteDoubleKeyFrame KeyTime="0:0:3.11" Value="0.08"/>
                    <DiscreteDoubleKeyFrame KeyTime="0:0:3.13" Value="0.00"/>
                    <DiscreteDoubleKeyFrame KeyTime="0:0:5.40" Value="0.00"/>
                    <DiscreteDoubleKeyFrame KeyTime="0:0:5.41" Value="0.05"/>
                    <DiscreteDoubleKeyFrame KeyTime="0:0:5.44" Value="0.03"/>
                    <DiscreteDoubleKeyFrame KeyTime="0:0:5.46" Value="0.00"/>
                    <DiscreteDoubleKeyFrame KeyTime="0:0:6.00" Value="0.00"/>
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>

            <!-- Top bar slide-in -->
            <Storyboard x:Key="HeaderSlideStoryboard">
                <DoubleAnimation Storyboard.TargetName="headerTranslate"
                                 Storyboard.TargetProperty="X"
                                 From="-400" To="0"
                                 Duration="0:0:0.7">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="headerPanel"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0" To="1"
                                 Duration="0:0:0.5"/>
            </Storyboard>

            <!-- Content fade-in stagger -->
            <Storyboard x:Key="ContentFadeStoryboard">
                <DoubleAnimation Storyboard.TargetName="contentArea"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0" To="1"
                                 BeginTime="0:0:0.6"
                                 Duration="0:0:0.8"/>
                <DoubleAnimation Storyboard.TargetName="contentTranslate"
                                 Storyboard.TargetProperty="Y"
                                 From="30" To="0"
                                 BeginTime="0:0:0.6"
                                 Duration="0:0:0.7">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

        </Grid.Resources>

        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard Storyboard="{StaticResource ScanlineStoryboard}"/>
            </EventTrigger>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard Storyboard="{StaticResource Scanline2Storyboard}"/>
            </EventTrigger>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard Storyboard="{StaticResource CursorBlinkStoryboard}"/>
            </EventTrigger>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard Storyboard="{StaticResource BorderPulseStoryboard}"/>
