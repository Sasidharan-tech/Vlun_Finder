<UserControl x:Class="SOCBOX.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource MainBackgroundBrush}">
    <Grid Margin="32">
        <StackPanel>
            <TextBlock Text="SOC Logs" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource NeonGreenBrush}" Margin="0,0,0,16"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Info" Style="{StaticResource GlowButtonStyle}" Width="80" Margin="0,0,8,0"/>
                <Button Content="Warning" Style="{StaticResource GlowButtonStyle}" Width="80" Margin="0,0,8,0"/>
                <Button Content="Critical" Style="{StaticResource GlowButtonStyle}" Width="80"/>
            </StackPanel>
            <Border Background="#000" CornerRadius="10" Padding="16" Effect="{DynamicResource CardGlowEffect}">
                <ScrollViewer Height="260" VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="[12:02:01] [INFO] > System initialized.&#x0a;[12:02:02] [WARNING] > High memory usage detected.&#x0a;[12:02:03] [CRITICAL] > Intrusion detected!&#x0a;[12:02:04] [INFO] > Scan completed." Foreground="#00ff9f" FontFamily="Consolas" FontSize="13"/>
                </ScrollViewer>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>