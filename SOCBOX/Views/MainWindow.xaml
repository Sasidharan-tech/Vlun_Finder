<Window x:Class="SOCBOX.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SOCBOX.Views"
        Title="SOCBOX" Height="700" Width="1200"
        WindowStyle="None" AllowsTransparency="True" Background="{DynamicResource MainBackgroundBrush}">
    <Grid>
        <!-- Matrix Rain Animation (optional, to be implemented) -->
        <!-- Custom Header -->
        <Border Background="{DynamicResource SidebarBackgroundBrush}" Height="48" VerticalAlignment="Top">
            <DockPanel>
                <TextBlock Text="SOCBOX" FontFamily="Orbitron" FontSize="28" Foreground="{DynamicResource NeonGreenBrush}"
                           Margin="20,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right" Margin="0,0,10,0">
                    <!-- Minimize, Maximize, Close buttons (to be styled) -->
                    <Button Width="32" Height="32" Margin="4,0" Style="{StaticResource GlowButtonStyle}" Content="_"/>
                    <Button Width="32" Height="32" Margin="4,0" Style="{StaticResource GlowButtonStyle}" Content="☐"/>
                    <Button Width="32" Height="32" Margin="4,0" Style="{StaticResource GlowButtonStyle}" Content="✕"/>
                </StackPanel>
            </DockPanel>
        </Border>
        <!-- Sidebar -->
        <Border Background="{DynamicResource SidebarBackgroundBrush}" Width="180" VerticalAlignment="Stretch" HorizontalAlignment="Left" Margin="0,48,0,0">
            <StackPanel>
                <Button Style="{StaticResource GlowButtonStyle}" Margin="10,20,10,0" Height="48" Command="{Binding ShowDashboardCommand}">Dashboard</Button>
                <Button Style="{StaticResource GlowButtonStyle}" Margin="10,10,10,0" Height="48" Command="{Binding ShowScanCommand}">Scan Target</Button>
                <Button Style="{StaticResource GlowButtonStyle}" Margin="10,10,10,0" Height="48" Command="{Binding ShowVulnsCommand}">Vulnerabilities</Button>
                <Button Style="{StaticResource GlowButtonStyle}" Margin="10,10,10,0" Height="48" Command="{Binding ShowReportsCommand}">Reports</Button>
                <Button Style="{StaticResource GlowButtonStyle}" Margin="10,10,10,0" Height="48" Command="{Binding ShowLogsCommand}">Logs</Button>
                <Button Style="{StaticResource GlowButtonStyle}" Margin="10,10,10,0" Height="48" Command="{Binding ShowSettingsCommand}">Settings</Button>
            </StackPanel>
        </Border>
        <!-- Main Content Area -->
        <Border Background="{DynamicResource MainBackgroundBrush}" Margin="180,48,0,0">
            <ContentControl Content="{Binding CurrentView}"/>
        </Border>
    </Grid>
</Window>