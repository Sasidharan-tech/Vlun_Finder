<UserControl x:Class="SOCBOX.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource MainBackgroundBrush}">
    <Grid Margin="32">
        <StackPanel>
            <TextBlock Text="Scan Reports" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource NeonGreenBrush}" Margin="0,0,0,16"/>
            <UniformGrid Columns="2" Rows="2" Margin="0,0,0,16">
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Margin="8" Padding="16" Effect="{DynamicResource CardGlowEffect}">
                    <StackPanel>
                        <TextBlock Text="Scan #1" Foreground="{DynamicResource NeonGreenBrush}" FontWeight="Bold"/>
                        <TextBlock Text="Target: example.com" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Vulnerabilities: 3" Foreground="{DynamicResource DangerRedBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Export PDF" Style="{StaticResource GlowButtonStyle}" Width="100" Margin="0,0,8,0"/>
                            <Button Content="Export JSON" Style="{StaticResource GlowButtonStyle}" Width="100"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <!-- More cards as needed -->
            </UniformGrid>
        </StackPanel>
    </Grid>
</UserControl>